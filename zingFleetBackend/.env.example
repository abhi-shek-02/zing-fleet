# ===========================================
# ZingCab Fleet Backend — copy to .env and fill values (never commit .env)
# ===========================================

# Supabase — Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres URL (optional — for psql migrations only)
SUPABASE_DB_URL=

# Optional: override Savaari booking API base URL (default is in routes/savaari.js)
# SAVAARI_BOOKING_API_URL=https://vendor.savaari.com/vendor/api/booking/v1/booking.php

# Server
PORT=3001
NODE_ENV=development

# CORS — comma-separated origins (no spaces). Code also allows localhost and zing-fleet.vercel.app by default.
# FRONTEND_URL=

# Admin PIN for POST /api/auth/login
ADMIN_PIN=1234
