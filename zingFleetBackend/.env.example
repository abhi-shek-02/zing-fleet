# ===========================================
# ZingCab Fleet Backend — Environment Variables
# ===========================================

# Supabase — Get these from your Supabase project settings → API
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Direct database connection (for running migrations)
SUPABASE_DB_URL=postgresql://postgres:password@db.yourproject.supabase.co:5432/postgres

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS whitelist)
FRONTEND_URL=http://localhost:5173

# Auth — PIN for admin login (change in production)
ADMIN_PIN=1234
